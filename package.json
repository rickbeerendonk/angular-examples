  "scripts": {
    "prettier": "prettier --list-different '**/*.{html,js,json,md,ts}'",
    "prettier-fix": "prettier --write '**/*.{html,js,json,md,ts}'",
    "openserver": "node ./server/server.js",
    "start": "npm run openserver -- \".\""
  },
  "dependencies": {
