    "@types/express": "^5",
    "@types/jasmine": "^5",
    "@types/node": "^25",
    "jasmine-core": "^6",
    "jsdom": "^29",
    "karma": "^6",
    "karma-chrome-launcher": "~3.2",
    "karma-coverage": "~2.2",
    "karma-jasmine": "~5.1",
    "karma-jasmine-html-reporter": "~2.2",
    "typescript": "~5.9.2",
    "husky": "^4",
    "prettier": "^3",
    "vitest": "^4"
