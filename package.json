    "@angular/forms": "^21.2",
    "@angular/localize": "^21.2",
    "@angular/material": "^21.2",
    "@angular/platform-browser": "^21.2",
    "@angular/platform-browser-dynamic": "^21.2",
    "@angular/platform-server": "^21.2",
    "@angular/pwa": "^21.2",
    "@angular/router": "^21.2",
    "@angular/service-worker": "^21.2",
    "@angular/ssr": "^21.2",
    "@ngrx/signals": "^21",
    "@ngrx/store": "^21",
    "@ngrx/store-devtools": "^21",
